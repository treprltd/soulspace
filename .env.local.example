# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Anthropic API ─────────────────────────────────────────────
# NEVER expose this to the client. Server-only.
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Encryption ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_key_here

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key
FROM_EMAIL=noreply@soulspacehealth.org

# ── Environment identifier ────────────────────────────────────
NEXT_PUBLIC_ENV=local

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Rate limiting (Upstash Redis) ─────────────────────────────
# Sign up free at https://console.upstash.com → create a Redis database
# Copy the REST URL and REST token from the database details page.
# When absent, rate limiting is skipped (safe for local dev).
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ── Sentry (error tracking) ───────────────────────────────────
# Sign up free at https://sentry.io → create a Next.js project
# NEXT_PUBLIC_SENTRY_DSN is safe to expose (it only accepts events, no read access)
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXX
# Build-time only — used to upload source maps. Never exposed to clients.
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=soulspace
SENTRY_AUTH_TOKEN=sntrys_your_auth_token_here
